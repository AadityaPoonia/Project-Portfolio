# ============================================
# Multi-Agent AI System - Environment Config
# ============================================

# Optional OpenAI override. OpenAI is used only when both values are present.
OPENAI_API_KEY=
OPENAI_MODEL=

# Default fallback provider.
# Get a Groq key at: https://console.groq.com/keys
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
APP_ENV=development

# Model behavior.
LLM_TEMPERATURE=0.0

# Optional pricing override in USD per 1M tokens.
# Use this when your provider/model is not listed in config.py or prices change.
LLM_INPUT_PRICE_PER_MILLION=
LLM_OUTPUT_PRICE_PER_MILLION=
CSV_QUERY_TIMEOUT_SECONDS=5
MAX_UPLOAD_MB=25

# Local embeddings for document RAG.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# MongoDB connection for LangGraph checkpoints.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=agent_platform

# Local data paths.
CSV_DATA_PATH=data/tourism_trends.csv
SQLITE_DATA_PATH=data/airlines.sqlite
VECTORSTORE_PATH=vectorstore/faiss_index

# Multimodal RAG controls.
RAG_ENABLE_OCR=true
RAG_ENABLE_TABLE_EXTRACTION=true
RAG_ENABLE_VISION_CAPTIONS=true
RAG_MAX_IMAGES_PER_PAGE=3
